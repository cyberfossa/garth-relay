# garth-relay — environment variables (APP_ prefix, loaded by environ-config)
# Copy to .env.local and fill in real values:
#   cp .env.example .env.local

# Google Cloud
APP_GCP_PROJECT_ID=your-gcp-project-id

# Encryption — 32-byte AES key, base64url-encoded (no padding)
# Generate: python3 -c "import os, base64; print(base64.urlsafe_b64encode(os.urandom(32)).rstrip(b'=').decode())"
APP_ENCRYPTION_KEY=

# JWT Sessions
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
APP_JWT_SECRET_KEY=
# APP_JWT_ALGORITHM=HS256

# CSRF double-submit secret
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
APP_CSRF_SECRET=

# Google OAuth 2.0 (from GCP Console > APIs & Services > Credentials)
APP_GOOGLE_CLIENT_ID=
APP_GOOGLE_CLIENT_SECRET=
# APP_GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8080/connections/google/callback

# Polling
# APP_POLLING_ENABLED=true
# APP_POLLING_INTERVAL_HOURS=1

# App
# APP_DEBUG=false
# APP_LOG_LEVEL=INFO

# Local development (not APP_ prefix — used by Google Cloud SDK)
# FIRESTORE_EMULATOR_HOST=localhost:8080

# === Docker Compose Local Development ===
# Run locally with: docker-compose up -d
#
# These variables are set automatically by docker-compose.yml (no action needed):
#   FIRESTORE_EMULATOR_HOST=firebase-emulator:8081
#   APP_GCP_PROJECT_ID=demo-local
#   APP_GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/auth/callback
#
# Required from developer (get from Google Cloud Console):
# APP_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# APP_GOOGLE_CLIENT_SECRET=your-client-secret
#
# NOTE: OAuth flows (login, connect Google Fit) require real Google credentials.
# The app will start without them, but auth endpoints will fail.
# Copy this file to .env and fill in your credentials before running.
